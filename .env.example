# PostgreSQL database connection string
# Format: postgres://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgres://postgres:password@localhost:5432/minivault

# PostgreSQL passwords for different configurations
DOCKER_POSTGRESQL_PASSWORD=your_docker_postgres_password
WINDOWS_POSTGRES_PASSWORD=your_windows_postgres_password

# Port configuration
PORT=3000

# JWT secret key — used to sign and verify authentication tokens
# Use a long, random string in production (e.g., run: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here
